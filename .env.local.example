# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key - server-only secret, used exclusively to create
# captain/owner accounts from the user-management screen. NEVER expose
# this to the browser (no NEXT_PUBLIC_ prefix) and never commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: enables AI receipt/contract scanning (expense quick-add,
# MYBA contract upload). Without it, those forms just skip the
# auto-fill step and stay manual.
ANTHROPIC_API_KEY=your-anthropic-api-key
