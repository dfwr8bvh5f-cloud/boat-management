# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key - server-only secret, used exclusively to create
# captain/owner accounts from the user-management screen. NEVER expose
# this to the browser (no NEXT_PUBLIC_ prefix) and never commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: enables AI receipt/contract scanning (expense quick-add,
# MYBA contract upload). Without it, those forms just skip the
# auto-fill step and stay manual.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: only needed to run the browser-based review agent (npm run
# test:e2e, or the /review-app command). BASE_URL is the running app to
# test against; DEMO_USER_EMAIL/PASSWORD is an account the agent logs in
# as. Never point these at data you're not comfortable having screenshotted
# and clicked through - prefer a dedicated demo/staging account over a real
# production one. Without these set, e2e tests fail fast with a clear
# message instead of hanging.
BASE_URL=http://localhost:3000
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=your-demo-account-password
